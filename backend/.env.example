# backend/.env.example
# Copiar a .env para desarrollo local — NUNCA subir .env al repositorio

# Conexión a Neon PostgreSQL (serverless)
# Obtener desde: https://console.neon.tech → tu proyecto → Connection string
DATABASE_URL=postgresql://neondb_owner:npg_h1GytIF6MVcQ@ep-withered-rain-adx73ihx-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# API Key que deben enviar los clientes en el header X-API-Key
# Generar con: openssl rand -hex 32
API_KEY=cambia_este_valor_por_una_clave_segura_de_64_caracteres

# Política de bloqueo por intentos fallidos
MAX_FAILED_ATTEMPTS=3
LOCKOUT_MINUTES=5

# Entorno
NODE_ENV=development
