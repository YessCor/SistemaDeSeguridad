# backend/Dockerfile
# Backend del Sistema de Seguridad - Imagen para desarrollo local

# ============================================================
# IMAGEN BASE
# ============================================================
FROM node:18-alpine

# ============================================================
# METADATA
# ============================================================
LABEL maintainer="Sistema de Seguridad"
LABEL description="Backend API REST para sistema de seguridad"

# ============================================================
# VARIABLES DE ENTORNO
# ============================================================
ENV NODE_ENV=production \
    PORT=3000

# ============================================================
# DIRECTORIO DE TRABAJO
# ============================================================
WORKDIR /app

# ============================================================
# COPIAR PACKAGE FILES
# ============================================================
COPY package*.json ./

# ============================================================
# INSTALAR DEPENDENCIAS
# ============================================================
RUN npm ci --only=production

# ============================================================
# COPIAR CÓDIGO FUENTE
# ============================================================
COPY . .

# ============================================================
# CREAR DIRECTORIO DE LOGS
# ============================================================
RUN mkdir -p /app/logs

# ============================================================
# EXPONER PUERTO
# ============================================================
EXPOSE 3000

# ============================================================
# PUNTO DE ENTRADA
# ============================================================
CMD ["node", "api/login.js"]
