# local-system/.env.example
# Copiar a .env y completar con valores reales
# ⚠ NUNCA subir .env al repositorio

# URL del backend desplegado en Vercel
BACKEND_URL=https://tu-proyecto.vercel.app

# API Key para autenticar con el backend (generar con: openssl rand -hex 32)
API_KEY=cambia_este_valor_por_una_clave_segura

# Reconocimiento facial
FACE_TOLERANCE=0.50
FACE_MODEL=large

# Liveness detection
BLINK_THRESHOLD=0.25
BLINKS_REQUIRED=2
HEAD_ANGLE_THRESHOLD=15.0

# Seguridad
MAX_FAILED_ATTEMPTS=3
LOCKOUT_MINUTES=5

# Cámara
CAMERA_INDEX=0
FRAME_WIDTH=640
FRAME_HEIGHT=480
TARGET_FPS=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/system.log
